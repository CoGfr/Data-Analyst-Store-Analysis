      <aliases enabled='yes' />
      <column caption='YOY Order Volume' datatype='real' name='[CY Order Volume (copy)_0953873555738629]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT(IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)])) } THEN [Order Id] END)&#13;&#10;- COUNT(IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)]))-1 } THEN [Order Id] END))&#13;&#10;/ COUNT(IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)]))-1 } THEN [Order Id] END)' />
      </column>
      <column caption='Late_delivery_risk_TF' datatype='boolean' name='[Calculation_0111645585371136]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Late_delivery_risk]=1' />
      </column>
      <column caption='% Late delivery' datatype='real' default-format='p0.0%' name='[Calculation_0642711407484929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Delivery Status] = &quot;Late delivery&quot; THEN [Order Id] END) &#13;&#10;/ &#13;&#10;COUNT([Order Id])' />
      </column>
      <column caption='Delivery difference days' datatype='integer' name='[Calculation_0642711413923842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Days for shipping (real)]-[Days for shipment (scheduled)]' />
      </column>
      <column caption='CY Sales' datatype='real' name='[Calculation_0953873546752000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)])) } THEN [Sales] END' />
      </column>
      <column caption='CY Order Volume' datatype='integer' name='[Calculation_0953873547464705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)])) } THEN [Order Id] END' />
      </column>
      <column caption='Yearly Average Delivery Time (Days)' datatype='integer' name='[Calculation_0953873547763714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)])) } THEN [Days for shipping (real)] END' />
      </column>
      <column caption='Yearly Average Delivery Variance' datatype='real' name='[Calculation_0953873548234755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF YEAR([order date (DateOrders)]) = { FIXED : MAX(YEAR([order date (DateOrders)])) } THEN (-[Days for shipping (real)]+[Days for shipment (scheduled)]) END)' />
      </column>
      <column caption='Yearly Global Delay Rate' datatype='real' name='[Calculation_0953873549914116]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))} &#13;&#10;    AND [Delivery Status] = &quot;Late delivery&quot; &#13;&#10;    THEN 1 ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))} &#13;&#10;    THEN 1 ELSE 0 END)' />
