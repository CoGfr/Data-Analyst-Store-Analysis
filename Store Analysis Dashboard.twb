        <calculation class='tableau' formula='((SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))} &#13;&#10;    AND [Delivery Status] = &quot;Late delivery&quot; &#13;&#10;    THEN 1 ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))} &#13;&#10;    THEN 1 ELSE 0 END))&#13;&#10;-&#13;&#10;(SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))-1} &#13;&#10;    AND [Delivery Status] = &quot;Late delivery&quot; &#13;&#10;    THEN 1 ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([order date (DateOrders)]) = {FIXED : MAX(YEAR([order date (DateOrders)]))-1} &#13;&#10;    THEN 1 ELSE 0 END)))*10000' />
      </column>
      <column caption='Yearly Global Delay Rate YoY positive' datatype='real' name='[Yearly Global Delay Rate YoY (copy)_0953873562710027]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Yearly Global Delay Rate (copy)_0953873562431498] &gt;0 THEN [Yearly Global Delay Rate (copy)_0953873562431498]END' />
      </column>
      <column caption='Yearly Global Delay Rate YoY negative' datatype='real' name='[Yearly Global Delay Rate YoY positive (copy)_0953873562935308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Yearly Global Delay Rate (copy)_0953873562431498] &lt;= 0 THEN [Yearly Global Delay Rate (copy)_0953873562431498]END' />
      </column>
